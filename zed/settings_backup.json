{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "status_bar": {
    "active_language_button": true,
  },
  "tabs": {
    "git_status": true,
  },
  "title_bar": {
    "show_user_picture": false,
    "show_user_menu": true,
    "show_sign_in": false,
    "show_onboarding_banner": false,
    "show_menus": false,
    "show_branch_icon": true,
  },
  "toolbar": {
    "breadcrumbs": false,
    "code_actions": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "centered_layout": {
    "left_padding": 0.035,
    "right_padding": 0.035,
  },
  "scrollbar": {
    "show": "never",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },

  "buffer_font_family": "scientifica",
  "buffer_font_size": 21,
  "buffer_line_height": "standard",
  "show_whitespaces": "selection",

  "ui_font_family": "Departure Mono",
  "ui_font_size": 16.5,

  "theme": "Vercel Dark",
  "icon_theme": "Colored Zed Icons Theme Dark",
}
