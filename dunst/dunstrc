[global]
    font = JetBrainsMono Nerd Font 12
    
    background = "#070707"
    foreground = "#f8f8f8"
    
    border_width = 0
    
    corner_radius = 0
    
    offset = 8x8
    origin = top-right
    
    transparency = 0
    
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 2
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 0
    progress_bar_color = "#f8f8f8"
    
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    
    separator_color = "#f8f8f8"
    separator_height = 8
    
    format = "<b>%s</b>\n%b"
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    indicator_color = "#f8f8f8"
    
    timeout = 5
    idle_threshold = 120
    
    mouse_left_click = close
    mouse_middle_click = close_all
    mouse_right_click = context
